{
  "name": "vimpractice",
  "version": "1.0.1",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.jacob.vimpractice",
    "productName": "Vim Practice",
    "forceCodeSigning": false,
    "win": {
      "icon": "vimPracticeIcon.ico",
      "target": "nsis"
    },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Vim Practice",
    "uninstallDisplayName": "Vim Practice"
    }
  },

  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  }
}
